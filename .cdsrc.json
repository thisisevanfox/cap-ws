{
    "sql": {
        "native_hana_associations": false
    },
    "eventQueue": {
        "useAsCAPQueue": true,
        "configFilePath": "./srv/event-config.yml"
    },
    "requires": {
        "[development]": {
            "multitenancy": true,
            "db": {
                "kind": "sqlite",
                "credentials": {
                    "url": "db.sqlite"
                }
            },
            "auth": {
                "kind": "mocked-auth",
                "users": {
                    "alice": {
                        "tenant": "t1",
                        "password": "alice",
                        "id": "alice@wonderland.com"
                    },
                    "bob": {
                        "tenant": "t2",
                        "password": "bob",
                        "id": "bob@builder.com"
                    }
                }
            }
        },
        "[production]": {
            "cds.xt.DeploymentService": true,
            "auth": "xsuaa",
            "db": {
                "kind": "hana",
                "vcap": {
                    "label": "service-manager"
                }
            }
        },
        "multitenancy": true,
        "extensibility": true,
        "cds.xt.ExtensibilityService": true,
        "cds.xt.ModelProviderService": true,
        "cds.xt.SaasProvisioningService": true,
        "cds.xt.DeploymentService": true,
        "html5-repo": true,
        "portal": true
    },
    "profile": "with-mtx-sidecar"
}